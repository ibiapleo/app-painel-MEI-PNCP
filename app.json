{
  "expo": {
    "name": "Painel MEI PNCP",
    "slug": "app-painel-mei-pncp",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mypainelmeipncp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "IBGE_API": "https://servicodados.ibge.gov.br/api/v1"
    }
  }
}
